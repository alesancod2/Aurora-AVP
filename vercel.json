{
  "functions": {
    "api/proxy.js": {
      "maxDuration": 120
    },
    "api/sync.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/sync?tipo=incremental",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/sync?tipo=consultores",
      "schedule": "0 */1 * * *"
    },
    {
      "path": "/api/sync?tipo=full",
      "schedule": "0 3 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}

